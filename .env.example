# Backend Configuration
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# Frontend Configuration
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=8501

# Neo4j Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here

# Kafka Configuration
KAFKA_BROKER=localhost:9092
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_TELEMETRY=vehicle-telemetry
KAFKA_STARTING_OFFSETS=latest
KAFKA_FAIL_ON_DATA_LOSS=false

# Spark Module 10 Configuration
APP_ENV=local
SPARK_MASTER=local[*]
SPARK_LOG_LEVEL=WARN
SPARK_SHUFFLE_PARTITIONS=4
SPARK_SQL_TIMEZONE=UTC
SPARK_TRIGGER_PROCESSING_TIME=10 seconds
SPARK_WATERMARK_DELAY=10 minutes
SPARK_KAFKA_PACKAGE=org.apache.spark:spark-sql-kafka-0-10_2.13:4.1.2
BRONZE_PATH=data/lakehouse/bronze/vehicle_telemetry
SILVER_PATH=data/lakehouse/silver/vehicle_telemetry
BRONZE_CHECKPOINT=data/checkpoints/spark/bronze_vehicle_telemetry
SILVER_CHECKPOINT=data/checkpoints/spark/silver_vehicle_telemetry

# Airflow Configuration
AIRFLOW_HOME=./airflow
AIRFLOW__CORE__DAGS_FOLDER=./airflow/dags

# Application Settings
DEBUG=False
TESTING=False
LOG_LEVEL=INFO

# Data Paths
DATA_DIR=./data
